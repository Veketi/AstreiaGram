{
  "title": "Feed Service",
  "uid": "feed-service",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Requisições HTTP por status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(feed_service_http_requests_total[1m])",
          "legendFormat": "{{method}} {{path}} ({{status}})"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latência p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(feed_service_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Eventos Kafka processados",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "feed_service_kafka_events_processed_total",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s"
}
