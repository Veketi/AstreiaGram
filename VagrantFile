Vagrant.configure("2") do |config|
  # Usa a imagem estável do Ubuntu 22.04
  config.vm.box = "ubuntu/jammy64"
  
  # Configura um IP estático para conseguir aceder às APIs e ao Godot
  config.vm.network "private_network", ip: "192.168.56.10"

  # Define os recursos da máquina (microsserviços exigem um pouco de memória)
  config.vm.provider "virtualbox" do |vb|
    vb.memory = "4096"
    vb.cpus = 2
  end

  # Provisionamento automático usando o Ansible
  config.vm.provision "ansible_local" do |ansible|
    ansible.playbook = "provisioning/playbook.yml"
  end
end